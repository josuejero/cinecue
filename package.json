{
  "name": "cinecue",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "npm run lint && npm run typecheck && npm run test && npm run build",
    "worker": "tsx src/worker/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "availability:sync": "tsx src/scripts/availability/sync.ts",
    "availability:rebuild-read-model": "tsx src/scripts/availability/rebuild-read-model.ts",
    "availability:sync-active": "tsx src/scripts/availability/sync-active.ts",
    "availability:replay-location": "tsx src/scripts/availability/replay-location.ts",
    "availability:replay-movie": "tsx src/scripts/availability/replay-movie.ts",
    "notifications:send-email": "tsx src/scripts/notifications/send-email.ts",
    "notifications:send-push": "tsx src/scripts/notifications/send-push.ts",
    "worker:schedulers": "tsx src/scripts/worker/schedulers.ts",
    "ops:report": "tsx src/scripts/ops/report.ts",
    "ops:cutover-runtime-ids": "tsx src/scripts/ops/cutover-runtime-ids.ts",
    "vapid:generate": "web-push generate-vapid-keys"
  },
  "dependencies": {
    "bullmq": "5.71.0",
    "dotenv": "17.3.1",
    "drizzle-orm": "0.45.1",
    "ioredis": "5.10.1",
    "next": "16.2.0",
    "next-auth": "5.0.0-beta.30",
    "nodemailer": "7.0.13",
    "pg": "8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "web-push": "3.6.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "7.0.1",
    "@types/pg": "8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "0.31.10",
    "esbuild": "0.27.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "tsx": "4.21.0",
    "typescript": "^5",
    "vitest": "4.1.0"
  }
}
