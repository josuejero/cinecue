# Copy this file to `.env` and replace placeholder values before running provider-backed flows.
# The Gracenote client refuses to sync while GRACENOTE_API_KEY still matches the placeholder below.
# Next.js automatically sets NODE_ENV for builds, so do not pin it here.

DATABASE_URL=postgresql://cinecue:cinecue@localhost:5432/cinecue
REDIS_URL=redis://localhost:6379

AUTH_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

APP_BASE_URL=http://localhost:3000

# Uncomment and replace these if you want email delivery locally.
# SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password
SMTP_FROM=CineCue <alerts@example.com>

GRACENOTE_BASE_URL=http://data.tmsapi.com/v1.1
GRACENOTE_API_KEY=REPLACE_WITH_REAL_GRACENOTE_KEY
GRACENOTE_MEDIA_CLOUD_BASE_URL=https://developer.tmsimg.com

TMDB_BASE_URL=https://api.themoviedb.org/3
# Set either TMDB_READ_ACCESS_TOKEN or TMDB_API_KEY before using TMDB enrichment.
# TMDB_READ_ACCESS_TOKEN=REPLACE_WITH_REAL_TMDB_READ_ACCESS_TOKEN
# TMDB_API_KEY=REPLACE_WITH_REAL_TMDB_API_KEY

PHASE1_TEST_ZIP=10001

PHASE4_ENABLE_SCHEDULERS=true
PHASE4_SYNC_INTERVAL_MINUTES=15
PHASE4_SYNC_NUM_DAYS=14
PHASE4_ACTIVE_LOCATION_LIMIT=200
PHASE4_LOCATION_SYNC_CONCURRENCY=6
PHASE4_NOTIFICATION_INTERVAL_MINUTES=10
PHASE4_NOTIFICATION_BATCH_SIZE=200
PHASE4_FUTURE_RELEASES_INTERVAL_MINUTES=360
PHASE4_FUTURE_RELEASES_NUM_DAYS=60
PHASE4_SHOWTIME_RETENTION_DAYS=21
PHASE4_JOB_RUN_RETENTION_DAYS=30
PHASE4_STALE_AFTER_MINUTES=90
PHASE4_FINAL_SHOWING_SOON_HOURS=24
PHASE4_SYNC_COUNTRY=USA

# Generate VAPID keys with `npm run vapid:generate`, then paste them below.
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:alerts@example.com

PHASE5_PUSH_INTERVAL_MINUTES=1
PHASE5_PUSH_BATCH_SIZE=100
PHASE5_SSE_HEARTBEAT_MS=15000
PHASE5_SSE_POLL_MS=15000

PHASE6_DASHBOARD_CACHE_TTL_SECONDS=30
PHASE6_ANALYTICS_WINDOW_DAYS=30
PHASE6_CALENDAR_DEFAULT_DURATION_MINUTES=150
